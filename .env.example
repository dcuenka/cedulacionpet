# Copia este archivo a .env y rellena los valores.

# --- BASE DE DATOS: PostgreSQL (Neon / Vercel Postgres) ---
# En Neon copia las DOS cadenas de conexión:
#   - Pooled  (con -pooler)  -> DATABASE_URL
#   - Direct  (sin -pooler)  -> DIRECT_URL   (necesaria para migraciones)
DATABASE_URL="postgresql://usuario:password@ep-xxxx-pooler.us-east-2.aws.neon.tech/cedulacionpet?sslmode=require"
DIRECT_URL="postgresql://usuario:password@ep-xxxx.us-east-2.aws.neon.tech/cedulacionpet?sslmode=require"

# URL pública del sitio. ES LA QUE SE CODIFICA DENTRO DEL QR de cada cédula,
# así que debe ser la URL final de producción.
# En local: http://localhost:3000
NEXT_PUBLIC_SITE_URL="https://cedulacionpet.vercel.app"

# Contraseña del panel de administración (respaldo de todos los registros).
ADMIN_PASSWORD="cambia-esta-clave"

# Secreto para firmar la cookie de sesión del admin (mín. 32 caracteres).
# Genera uno con: openssl rand -base64 32
ADMIN_SESSION_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
